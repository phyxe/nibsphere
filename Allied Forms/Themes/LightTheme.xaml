<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <SolidColorBrush x:Key="Brush.Background" Color="#FFEFF1F3"/>
    <SolidColorBrush x:Key="Brush.Surface" Color="#FFFFFFFF"/>
    <SolidColorBrush x:Key="Brush.SurfaceAlt" Color="#FFDBD3D8"/>
    <SolidColorBrush x:Key="Brush.Border" Color="#FFDBD3D8"/>

    <SolidColorBrush x:Key="Brush.PrimaryText" Color="#FF223843"/>
    <SolidColorBrush x:Key="Brush.SecondaryText" Color="#FF4A5A62"/>
    <SolidColorBrush x:Key="Brush.MutedText" Color="#FF6D7A80"/>

    <SolidColorBrush x:Key="Brush.PrimaryAccent" Color="#FFD77A61"/>
    <SolidColorBrush x:Key="Brush.PrimaryAccentHover" Color="#FFC96B55"/>
    <SolidColorBrush x:Key="Brush.SecondaryAccent" Color="#FFD8B4A0"/>

    <SolidColorBrush x:Key="Brush.NavBackground" Color="#FF223843"/>
    <SolidColorBrush x:Key="Brush.NavItemHover" Color="#FF2D4A56"/>
    <SolidColorBrush x:Key="Brush.NavItemActive" Color="#FFD77A61"/>

    <SolidColorBrush x:Key="Brush.NavIcon" Color="#FFFFFF"/>

</ResourceDictionary>