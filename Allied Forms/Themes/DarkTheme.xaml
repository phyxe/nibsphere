    <SolidColorBrush x:Key="Brush.Background" Color="#FF18272F"/>
    <SolidColorBrush x:Key="Brush.Surface" Color="#FF223843"/>
    <SolidColorBrush x:Key="Brush.SurfaceAlt" Color="#FF2A3F49"/>
