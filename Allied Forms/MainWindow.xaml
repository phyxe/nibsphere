<Window x:Class="Allied_Forms.MainWindow"
		xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
		xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
		xmlns:svg="http://sharpvectors.codeplex.com/runtime/"
		xmlns:svgc="http://sharpvectors.codeplex.com/svgc/"
		mc:Ignorable="d"
		Title="Allied Forms"
		Width="1280"
		Height="800"
		MinWidth="1000"
		MinHeight="650"
		WindowStartupLocation="CenterScreen"
		Background="{DynamicResource Brush.Background}">

    <Border BorderBrush="{DynamicResource Brush.Border}"
			BorderThickness="1"
			Background="{DynamicResource Brush.Background}">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="52"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Command Strip -->
            <Border Grid.Row="0"
					Background="{DynamicResource Brush.Surface}"
					BorderBrush="{DynamicResource Brush.Border}"
					BorderThickness="0,0,0,1"
					Padding="12,6">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal"
								VerticalAlignment="Center">
                        <Button Content="New"
								MinWidth="82"
								Margin="0,0,8,0"/>
                        <Button Content="Edit"
								MinWidth="82"
								Margin="0,0,8,0"/>
                        <Button Content="Save"
								MinWidth="82"
								Margin="0,0,8,0"/>
                        <Button Content="Refresh"
								MinWidth="82"
								Margin="0,0,8,0"/>
                        <Button Content="Export"
								MinWidth="82"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1"
								Orientation="Horizontal"
								VerticalAlignment="Center">
                        <Button Content="Light"
								MinWidth="72"
								Margin="0,0,8,0"/>
                        <Button Content="Dark"
								MinWidth="72"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Main Workspace -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="NavColumn" Width="220"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left Navigation -->
                <Border Grid.Column="0"
						Background="{DynamicResource Brush.NavBackground}"
						BorderBrush="{DynamicResource Brush.Border}"
						BorderThickness="0,0,1,0">

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="52"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Nav Header -->
                        <Grid Grid.Row="0"
							  Margin="10,8,10,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="36"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Button x:Name="NavToggleButton"
									Width="36"
									Height="36"
									Content="☰"
									FontSize="16"
									HorizontalAlignment="Left"
									VerticalAlignment="Center"
									Background="{DynamicResource Brush.NavItemHover}"
									BorderBrush="{DynamicResource Brush.NavItemHover}"
									Foreground="White"
									Click="NavToggleButton_Click"/>

                            <TextBlock x:Name="NavHeaderText"
									   Grid.Column="1"
									   Text="FEATURES"
									   Margin="10,0,0,0"
									   VerticalAlignment="Center"
									   Foreground="White"
									   Style="{StaticResource TextBlock.Body}"/>
                        </Grid>

                        <!-- Nav Items -->
                        <ScrollViewer Grid.Row="1"
									  VerticalScrollBarVisibility="Auto"
									  HorizontalScrollBarVisibility="Disabled">
                            <StackPanel Margin="10,4,10,10">

                                <Button x:Name="DashboardNavButton"
										Height="42"
										Margin="0,0,0,8"
										HorizontalContentAlignment="Left"
										Background="{DynamicResource Brush.NavItemActive}"
										BorderBrush="{DynamicResource Brush.NavItemActive}">
                                    <StackPanel Orientation="Horizontal">
                                        <svgc:SvgIcon Width="18"
													Height="18"
													Fill="{DynamicResource Brush.NavIcon}"
													UriSource="/Resources/Icons/home.svg"
													AppName="Allied Forms" />
                                        <TextBlock x:Name="DashboardNavText"
												   Text="Dashboard"
												   Margin="12,0,0,0"
												   Foreground="{DynamicResource Brush.NavIcon}"
												   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>

                                <Button x:Name="StudentsNavButton"
										Height="42"
										Margin="0,0,0,8"
										HorizontalContentAlignment="Left"
										Background="Transparent"
										BorderBrush="Transparent">
                                    <StackPanel Orientation="Horizontal">
                                        <svgc:SvgIcon Width="18"
													Height="18"
													Fill="{DynamicResource Brush.NavIcon}"
													UriSource="/Resources/Icons/student.svg"
													AppName="Allied Forms" />
                                        <TextBlock x:Name="StudentsNavText"
												   Text="Students"
												   Margin="12,0,0,0"
												   Foreground="{DynamicResource Brush.NavIcon}"
												   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>

                                <Button x:Name="ReportsNavButton"
										Height="42"
										Margin="0,0,0,8"
										HorizontalContentAlignment="Left"
										Background="Transparent"
										BorderBrush="Transparent">
                                    <StackPanel Orientation="Horizontal">
                                        <svgc:SvgIcon Width="18"
													Height="18"
													Fill="{DynamicResource Brush.NavIcon}"
													UriSource="/Resources/Icons/document.svg"
													AppName="Allied Forms" />
                                        <TextBlock x:Name="ReportsNavText"
												   Text="Reports"
												   Margin="12,0,0,0"
												   Foreground="{DynamicResource Brush.NavIcon}"
												   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </ScrollViewer>
                        <!-- Nav Bottom Section -->
                        <Border Grid.Row="2"
                            BorderBrush="{DynamicResource Brush.NavItemHover}"
                            BorderThickness="0,1,0,0"
                            Padding="10">

                            <Grid Height="42">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="42" />
                                    <ColumnDefinition Width="42" />
                                </Grid.ColumnDefinitions>
                                
                                <Button x:Name="ThemeToggleNavButton"
                                    Grid.Column="2"
                                    Width="36"
                                    Height="36"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Background="Transparent"
                                    BorderBrush="Transparent"
                                    Padding="0"
                                    ToolTip="Toggle theme">
                                    <Viewbox Width="24" Height="24" Stretch="Uniform">
                                        <svgc:SvgIcon Fill="{DynamicResource Brush.NavIcon}"
                                            UriSource="/Resources/Icons/themedark.svg"
                                            AppName="Allied Forms" />
                                    </Viewbox>
                                </Button>

                                <Button x:Name="BottomSettingsNavButton"
                                    Grid.Column="0"
                                    Width="36"
                                    Height="36"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Background="Transparent"
                                    BorderBrush="Transparent"
                                    Padding="0"
                                    ToolTip="Settings"
                                    Click="BottomSettingsNavButton_Click">
                                    <Viewbox Width="18" Height="18" Stretch="Uniform">
                                        <svgc:SvgIcon Fill="{DynamicResource Brush.NavIcon}"
                                            UriSource="/Resources/Icons/settings.svg"
                                            AppName="Allied Forms" />
                                    </Viewbox>
                                </Button>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <!-- Content Area -->
                <Grid Grid.Column="1"
					  Background="{DynamicResource Brush.Background}">
                    <Border Margin="16"
							Style="{StaticResource CardBorderStyle}">
                        <ContentControl x:Name="MainContentHost">
                            <Border Background="{DynamicResource Brush.SurfaceAlt}"
                                CornerRadius="20"
                                Padding="20">
                                <TextBlock Text="Main content host"
                                    Style="{StaticResource TextBlock.Body}" />
                            </Border>
                        </ContentControl>
                    </Border>
                </Grid>
            </Grid>

            <!-- Status Bar -->
            <Border Grid.Row="2"
					Background="{DynamicResource Brush.Surface}"
					BorderBrush="{DynamicResource Brush.Border}"
					BorderThickness="0,1,0,0"
					Padding="10,0">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Ready"
							   VerticalAlignment="Center"
							   Style="{StaticResource TextBlock.Caption}"/>

                    <TextBlock Grid.Column="1"
							   Text="School: Not set"
							   Margin="0,0,16,0"
							   VerticalAlignment="Center"
							   Style="{StaticResource TextBlock.Caption}"/>

                    <TextBlock Grid.Column="2"
							   Text="Theme: Light"
							   VerticalAlignment="Center"
							   Style="{StaticResource TextBlock.Caption}"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>