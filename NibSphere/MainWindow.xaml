<Window x:Class="NibSphere.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:NibSphere.Controls"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        mc:Ignorable="d"
        Title="NibSphere"
        Width="1280"
        Height="800"
        MinWidth="1000"
        MinHeight="650"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        StateChanged="MainWindow_StateChanged"
        Background="{DynamicResource Brush.Background}">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="40"
                            ResizeBorderThickness="6"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <Style x:Key="TitleBarButtonStyle" TargetType="Button">
            <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True" />
            <Setter Property="Width" Value="46" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.TitleBarForeground}" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder"
                                        Property="Background"
                                        Value="{DynamicResource Brush.TitleBarButtonHoverBackground}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder"
                                        Property="Background"
                                        Value="{DynamicResource Brush.TitleBarButtonHoverBackground}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TitleBarCloseButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource TitleBarButtonStyle}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="White" />
                                <Setter TargetName="ButtonBorder"
                                        Property="Background"
                                        Value="{DynamicResource Brush.TitleBarCloseButtonHoverBackground}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Foreground" Value="White" />
                                <Setter TargetName="ButtonBorder"
                                        Property="Background"
                                        Value="{DynamicResource Brush.TitleBarCloseButtonHoverBackground}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border x:Name="WindowBorder"
            BorderBrush="{DynamicResource Brush.Border}"
			BorderThickness="1"
			Background="{DynamicResource Brush.Background}">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Border Grid.Row="0"
        Background="{DynamicResource Brush.TitleBarBackground}"
        BorderBrush="{DynamicResource Brush.Border}"
        BorderThickness="0,0,0,1">
                <Grid Height="40">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="46" />
                        <ColumnDefinition Width="46" />
                        <ColumnDefinition Width="46" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Margin="12,0,0,0"
                   VerticalAlignment="Center"
                   Foreground="{DynamicResource Brush.TitleBarForeground}"
                   FontSize="14"
                   FontWeight="SemiBold"
                   Text="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=Title}" />

                    <Button Grid.Column="1"
                Style="{StaticResource TitleBarButtonStyle}"
                Click="MinimizeButton_Click">
                        <TextBlock Text="&#xE921;"
                       FontFamily="Segoe MDL2 Assets"
                       FontSize="10"
                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                    </Button>

                    <Button Grid.Column="2"
                Style="{StaticResource TitleBarButtonStyle}"
                Click="MaximizeRestoreButton_Click">
                        <TextBlock x:Name="MaximizeRestoreGlyph"
                       Text="&#xE922;"
                       FontFamily="Segoe MDL2 Assets"
                       FontSize="10"
                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                    </Button>

                    <Button Grid.Column="3"
                Style="{StaticResource TitleBarCloseButtonStyle}"
                Click="CloseButton_Click">
                        <TextBlock Text="&#xE8BB;"
                       FontFamily="Segoe MDL2 Assets"
                       FontSize="10"
                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                    </Button>
                </Grid>
            </Border>

            <!-- Main Workspace -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="NavColumn" Width="220"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left Navigation -->
                <Border Grid.Column="0"
						Background="{DynamicResource Brush.NavBackground}"
						BorderBrush="{DynamicResource Brush.Border}"
						BorderThickness="0,0,1,0">

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="64"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Row 1: Brand -->
                        <Border Grid.Row="0"
                            BorderBrush="{DynamicResource Brush.NavItemHover}"
                            BorderThickness="0,0,0,1"
                            Padding="12,10,12,10">
                            <Grid Grid.Row="0"
                                Margin="12,8,12,8">
                                <Image x:Name="NavBrandImage"
                                   Height="28"
                                   HorizontalAlignment="Left"
                                   VerticalAlignment="Center"
                                   Stretch="Uniform"
                                   Source="/Resources/Brand/nibsphere-full.png" />
                            </Grid>
                        </Border>

                        <!-- Row 2: Scrollable module nav -->
                        <ScrollViewer Grid.Row="1"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
                            <StackPanel Margin="10,12,10,10">

                                <Button x:Name="DashboardNavButton"
                    Height="42"
                    Margin="0,0,0,8"
                    HorizontalContentAlignment="Left"
                    Background="{DynamicResource Brush.NavItemActive}"
                    BorderBrush="{DynamicResource Brush.NavItemActive}">
                                    <StackPanel Orientation="Horizontal">
                                        <controls:ControlSvgIcon Width="18"
                                             Height="18"
                                             Source="/Resources/Icons/dashboard.svg"
                                             Tint="{DynamicResource Brush.NavIcon}" />
                                        <TextBlock x:Name="DashboardNavText"
                               Text="Dashboard"
                               Margin="12,0,0,0"
                               Foreground="{DynamicResource Brush.NavIcon}"
                               VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>

                                <Button x:Name="StudentsNavButton"
                    Height="42"
                    Margin="0,0,0,8"
                    HorizontalContentAlignment="Left"
                    Background="Transparent"
                    BorderBrush="Transparent">
                                    <StackPanel Orientation="Horizontal">
                                        <controls:ControlSvgIcon Width="18"
                                             Height="18"
                                             Source="/Resources/Icons/student.svg"
                                             Tint="{DynamicResource Brush.NavIcon}" />
                                        <TextBlock x:Name="StudentsNavText"
                               Text="Students"
                               Margin="12,0,0,0"
                               Foreground="{DynamicResource Brush.NavIcon}"
                               VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>

                                <Button x:Name="ReportsNavButton"
                    Height="42"
                    Margin="0,0,0,8"
                    HorizontalContentAlignment="Left"
                    Background="Transparent"
                    BorderBrush="Transparent">
                                    <StackPanel Orientation="Horizontal">
                                        <controls:ControlSvgIcon Width="18"
                                             Height="18"
                                             Source="/Resources/Icons/report.svg"
                                             Tint="{DynamicResource Brush.NavIcon}" />
                                        <TextBlock x:Name="ReportsNavText"
                               Text="Reports"
                               Margin="12,0,0,0"
                               Foreground="{DynamicResource Brush.NavIcon}"
                               VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>

                                <Button x:Name="SchoolYearNavButton"
                    Height="42"
                    Margin="0,0,0,8"
                    HorizontalContentAlignment="Left"
                    Background="Transparent"
                    BorderBrush="Transparent">
                                    <StackPanel Orientation="Horizontal">
                                        <controls:ControlSvgIcon Width="18"
                                             Height="18"
                                             Source="/Resources/Icons/calendar.svg"
                                             Tint="{DynamicResource Brush.NavIcon}" />
                                        <TextBlock x:Name="SchoolYearNavText"
                               Text="School Year"
                               Margin="12,0,0,0"
                               Foreground="{DynamicResource Brush.NavIcon}"
                               VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </ScrollViewer>

                        <!-- Row 3: Sticky feature buttons -->
                        <Border Grid.Row="2"
            BorderBrush="{DynamicResource Brush.NavItemHover}"
            BorderThickness="0,1,0,0"
            Padding="10,10,10,10">
                            <StackPanel>
                                <Button x:Name="SchoolNavButton"
                    Height="42"
                    HorizontalContentAlignment="Left"
                    Background="Transparent"
                    BorderBrush="Transparent"
                    ToolTip="School">
                                    <StackPanel Orientation="Horizontal">
                                        <controls:ControlSvgIcon Width="18"
                                             Height="18"
                                             Source="/Resources/Icons/school.svg"
                                             Tint="{DynamicResource Brush.NavIcon}" />
                                        <TextBlock x:Name="SchoolNavText"
                               Text="School Information"
                               Margin="12,0,0,0"
                               Foreground="{DynamicResource Brush.NavIcon}"
                               VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Border>

                        <!-- Row 4: Utilities -->
                        <Border Grid.Row="3"
            BorderBrush="{DynamicResource Brush.NavItemHover}"
            BorderThickness="0,1,0,0"
            Padding="10">
                            <Grid Height="42">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="42" />
                                    <ColumnDefinition Width="42" />
                                </Grid.ColumnDefinitions>

                                <Button x:Name="ThemeToggleNavButton"
                    Grid.Column="1"
                    Width="36"
                    Height="36"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="Transparent"
                    BorderBrush="Transparent"
                    Padding="0"
                    ToolTip="Toggle theme"
                    Click="ThemeToggleNavButton_Click">
                                    <Viewbox Width="18" Height="18" Stretch="Uniform">
                                        <controls:ControlSvgIcon x:Name="ThemeToggleNavIcon"
                                             Width="18"
                                             Height="18"
                                             Source="/Resources/Icons/modedark.svg"
                                             Tint="{DynamicResource Brush.NavIcon}" />
                                    </Viewbox>
                                </Button>

                                <Button x:Name="UserProfileViewNavButton"
                    Grid.Column="0"
                    Width="36"
                    Height="36"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="Transparent"
                    BorderBrush="Transparent"
                    Padding="0"
                    ToolTip="Profile"
                    Click="UserProfileViewNavButton_Click">
                                    <Viewbox Width="18" Height="18" Stretch="Uniform">
                                        <controls:ControlSvgIcon x:Name="UserProfileViewNavIcon"
                                             Width="18"
                                             Height="18"
                                             Source="/Resources/Icons/userprofile.svg"
                                             Tint="{DynamicResource Brush.NavIcon}" />
                                    </Viewbox>
                                </Button>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>


                <!-- Left Navigation Collapse Button Area -->
                <Border Grid.Column="0"
                    Width="30"
                    Height="30"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="0,16,-15,0"
                    Panel.ZIndex="20"
                    Background="{DynamicResource Brush.Surface}"
                    BorderBrush="{DynamicResource Brush.Border}"
                    BorderThickness="1"
                    CornerRadius="15">
                    <Button x:Name="NavToggleButton"
                        Width="28"
                        Height="28"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        Padding="0"
                        ToolTip="Collapse navigation"
                        Click="NavToggleButton_Click">
                        <controls:ControlSvgIcon x:Name="NavToggleButtonIcon"
                                Width="16"
                                 Height="16"
                                 Source="/Resources/Icons/arrowleft.svg"
                                 Tint="{DynamicResource Brush.PrimaryText}" />
                    </Button>
                </Border>

                <!-- Content Area -->
                <Grid Grid.Column="1"
					  Background="{DynamicResource Brush.Background}">
                    <Border Margin="16"
							Style="{StaticResource CardBorderStyle}">
                        <ContentControl x:Name="MainContentHost">
                            <Border Background="{DynamicResource Brush.SurfaceAlt}"
                                CornerRadius="20"
                                Padding="20">
                                <TextBlock Text="Main content host"
                                    Style="{StaticResource TextBlock.Body}" />
                            </Border>
                        </ContentControl>
                    </Border>
                </Grid>
            </Grid>

            <!-- Status Bar -->
            <Border Grid.Row="2"
					Background="{DynamicResource Brush.Surface}"
					BorderBrush="{DynamicResource Brush.Border}"
					BorderThickness="0,1,0,0"
					Padding="10,0">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Ready"
							   VerticalAlignment="Center"
							   Style="{StaticResource TextBlock.Caption}"/>

                    <TextBlock Grid.Column="1"
							   Text="School: Not set"
							   Margin="0,0,16,0"
							   VerticalAlignment="Center"
							   Style="{StaticResource TextBlock.Caption}"/>

                    <TextBlock x:Name="ThemeStatusTextBlock"
                               Grid.Column="2"
							   Text="Theme: Light"
							   VerticalAlignment="Center"
							   Style="{StaticResource TextBlock.Caption}"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>