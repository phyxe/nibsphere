<UserControl x:Class="NibSphere.Views.UserProfileView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:controls="clr-namespace:NibSphere.Controls"
             mc:Ignorable="d"
             d:DesignHeight="700"
             d:DesignWidth="980"
             Background="{DynamicResource Brush.Background}">

    <UserControl.Resources>
        <Style x:Key="ProfileImageOverlayButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="{DynamicResource Brush.Surface}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="14">
                            <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder"
                                    Property="Background"
                                    Value="{DynamicResource Brush.IconButtonHoverBackground}" />
                                <Setter TargetName="ButtonBorder"
                                    Property="BorderBrush"
                                    Value="{DynamicResource Brush.PrimaryAccent}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder"
                                    Property="Background"
                                    Value="{DynamicResource Brush.IconButtonHoverBackground}" />
                                <Setter TargetName="ButtonBorder"
                                    Property="BorderBrush"
                                    Value="{DynamicResource Brush.PrimaryAccent}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.6" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="4">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="User Profile"
                       Style="{StaticResource TextBlock.Heading1}" />

            <Border Grid.Row="2"
                    Style="{StaticResource CardBorderStyle}">
                <StackPanel HorizontalAlignment="Center">
                    <Grid Width="132"
      Height="132"
      Margin="0,4,0,12">
                        <Ellipse x:Name="ProfileImageEllipse"
             Width="132"
             Height="132"
             Stroke="{DynamicResource Brush.Border}"
             StrokeThickness="1"
             Fill="{DynamicResource Brush.SurfaceAlt}" />

                        <TextBlock x:Name="ProfileInitialsTextBlock"
               HorizontalAlignment="Center"
               VerticalAlignment="Center"
               FontSize="30"
               FontWeight="SemiBold"
               Style="{StaticResource TextBlock.Heading2}"
               Text="IMG" />

                        <StackPanel x:Name="ProfileImageButtonsPanel"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Margin="0,0,-4,-4">
                            <Button x:Name="BrowseProfileImageButton"
                Style="{StaticResource ProfileImageOverlayButtonStyle}"
                Margin="0,0,6,0"
                Click="BrowseProfileImageButton_Click"
                ToolTip="Upload Image">
                                <controls:ControlSvgIcon Width="14"
                                     Height="14"
                                     Source="/Resources/Icons/upload.svg"
                                     Tint="{DynamicResource Brush.PrimaryText}" />
                            </Button>

                            <Button x:Name="RemoveProfileImageButton"
                Style="{StaticResource ProfileImageOverlayButtonStyle}"
                Click="RemoveProfileImageButton_Click"
                ToolTip="Remove Image">
                                <controls:ControlSvgIcon Width="14"
                                     Height="14"
                                     Source="/Resources/Icons/trash.svg"
                                     Tint="{DynamicResource Brush.PrimaryText}" />
                            </Button>
                        </StackPanel>
                    </Grid>

                    <TextBlock x:Name="ProfileHeaderNameTextBlock"
                               Text="USER PROFILE"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               Style="{StaticResource TextBlock.Heading2}" />

                    <TextBlock x:Name="ProfileHeaderPositionTextBlock"
                               Margin="0,2,0,0"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               Style="{StaticResource TextBlock.Secondary}"
                               Text="" />
                </StackPanel>
            </Border>

            <Border Grid.Row="4"
                    Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="20"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="20"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="20"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="24"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Profile Information"
                               Style="{StaticResource TextBlock.SectionTitle}" />

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="1.2*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="First Name"
                                       Margin="0,0,0,6"
                                       Style="{StaticResource TextBlock.Body}" />
                            <TextBox x:Name="FirstNameTextBox"
                                     MinHeight="36"
                                     TextChanged="ProfileFields_TextChanged" />
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Middle Name"
                                       Margin="0,0,0,6"
                                       Style="{StaticResource TextBlock.Body}" />
                            <TextBox x:Name="MiddleNameTextBox"
                                     MinHeight="36"
                                     TextChanged="ProfileFields_TextChanged" />
                        </StackPanel>

                        <StackPanel Grid.Column="4">
                            <TextBlock Text="Last Name"
                                       Margin="0,0,0,6"
                                       Style="{StaticResource TextBlock.Body}" />
                            <TextBox x:Name="LastNameTextBox"
                                     MinHeight="36"
                                     TextChanged="ProfileFields_TextChanged" />
                        </StackPanel>

                        <StackPanel Grid.Column="6">
                            <TextBlock Text="Extension"
                                       Margin="0,0,0,6"
                                       Style="{StaticResource TextBlock.Body}" />
                            <TextBox x:Name="ExtensionNameTextBox"
                                     MinHeight="36"
                                     TextChanged="ProfileFields_TextChanged" />
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.2*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="1.1*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="1.7*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Position Title"
                                       Margin="0,0,0,6"
                                       Style="{StaticResource TextBlock.Body}" />
                            <TextBox x:Name="PositionTitleTextBox"
                                     MinHeight="36"
                                     TextChanged="ProfileFields_TextChanged" />
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Contact Number"
                                       Margin="0,0,0,6"
                                       Style="{StaticResource TextBlock.Body}" />
                            <TextBox x:Name="ContactNumberTextBox"
                                     MinHeight="36" />
                        </StackPanel>

                        <StackPanel Grid.Column="4">
                            <TextBlock Text="Email Address"
                                       Margin="0,0,0,6"
                                       Style="{StaticResource TextBlock.Body}" />
                            <TextBox x:Name="EmailAddressTextBox"
                                     MinHeight="36" />
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="240"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Theme Preference"
                                       Margin="0,0,0,6"
                                       Style="{StaticResource TextBlock.Body}" />
                            <ComboBox x:Name="ThemePreferenceComboBox"
                                      MinHeight="36"
                                      SelectedIndex="0">
                                <ComboBoxItem Content="System" />
                                <ComboBoxItem Content="Light" />
                                <ComboBoxItem Content="Dark" />
                            </ComboBox>
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock x:Name="ProfileImagePathStatusTextBlock"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource TextBlock.Caption}"
                                   Visibility="Collapsed"
                                   Text="" />

                        <Button Grid.Column="1"
                                x:Name="SaveProfileButton"
                                Width="160"
                                HorizontalAlignment="Right"
                                Click="SaveProfileButton_Click">
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Center">
                                <controls:ControlSvgIcon x:Name="SaveProfileActionIcon"
                                                         Width="16"
                                                         Height="16"
                                                         Margin="0,0,8,0"
                                                         Source="/Resources/Icons/save.svg"
                                                         Tint="White" />
                                <TextBlock x:Name="SaveProfileActionTextBlock"
                                           VerticalAlignment="Center"
                                           Foreground="White"
                                           Text="Save Profile" />
                            </StackPanel>
                        </Button>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>