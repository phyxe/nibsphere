<Window x:Class="NibSphere.Views.LearningAreaImportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Import Learning Areas"
        Width="1120"
        Height="760"
        MinWidth="1000"
        MinHeight="680"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Brush.Background}">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="*" />
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="Import Learning Areas"
                   Style="{StaticResource TextBlock.Heading1}" />

        <TabControl x:Name="WizardTabControl"
                    Grid.Row="2">
            <TabItem x:Name="SourceFileTab"  Header="1. Source File">
                <Border Margin="4"
                        Style="{StaticResource CardBorderStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="16" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="20" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="20" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock Text="Select Source File"
                                   Style="{StaticResource TextBlock.SectionTitle}" />

                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="120" />
                            </Grid.ColumnDefinitions>

                            <TextBox x:Name="SelectedFilePathTextBox"
                                     IsReadOnly="True"
                                     MinHeight="36" />

                            <Button Grid.Column="2"
                                    MinWidth="120"
                                    Padding="14,8"
                                    Click="BrowseFileButton_Click">
                                <TextBlock Text="Browse..." />
                            </Button>
                        </Grid>

                        <Grid Grid.Row="4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.4*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Sheet"
                                           Margin="0,0,0,6"
                                           Style="{StaticResource TextBlock.Body}" />
                                <ComboBox x:Name="SheetComboBox"
                                          MinHeight="36"
                                          SelectionChanged="SheetComboBox_SelectionChanged" />
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Detected File Type"
                                           Margin="0,0,0,6"
                                           Style="{StaticResource TextBlock.Body}" />
                                <TextBox x:Name="DetectedFileTypeTextBox"
                                         IsReadOnly="True"
                                         MinHeight="36" />
                            </StackPanel>
                        </Grid>

                        <TextBox x:Name="SourceInfoTextBox"
                                 Grid.Row="6"
                                 IsReadOnly="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto" />
                    </Grid>
                </Border>
            </TabItem>

            <TabItem x:Name="FieldMappingTab" Header="2. Field Mapping">
                <Border Margin="4"
                        Style="{StaticResource CardBorderStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="16" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock Text="Map Source Columns to Target Fields"
                                   Style="{StaticResource TextBlock.SectionTitle}" />

                        <DataGrid Grid.Row="2"
                                  x:Name="MappingsDataGrid"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  HeadersVisibility="Column"
                                  RowHeaderWidth="0"
                                  MinHeight="420">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Target Field"
                                                    Binding="{Binding FieldLabel}"
                                                    Width="2*" />

                                <DataGridCheckBoxColumn Header="Required"
                                                        Binding="{Binding IsRequired}"
                                                        Width="90" />

                                <DataGridTemplateColumn Header="Source Column"
                                                        Width="2.5*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <ComboBox ItemsSource="{Binding AvailableSourceColumns}"
                                                      SelectedItem="{Binding SelectedSourceColumnHeader, UpdateSourceTrigger=PropertyChanged}"
                                                      MinHeight="32" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </TabItem>

            <TabItem x:Name="SimulateTab" Header="3. Simulate">
                <Border Margin="4"
                        Style="{StaticResource CardBorderStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="16" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="16" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock Text="Simulation Preview"
                                   Style="{StaticResource TextBlock.SectionTitle}" />

                        <TextBox x:Name="SimulationSummaryTextBox"
                                 Grid.Row="2"
                                 IsReadOnly="True"
                                 TextWrapping="Wrap" />

                        <DataGrid x:Name="SimulationPreviewDataGrid"
                                  Grid.Row="4"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  HeadersVisibility="Column"
                                  IsReadOnly="True"
                                  RowHeaderWidth="0"
                                  MinHeight="360">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Row"
                                                    Binding="{Binding SourceRowNumber}"
                                                    Width="70" />

                                <DataGridTextColumn Header="Code"
                                                    Binding="{Binding Code}"
                                                    Width="*" />

                                <DataGridTextColumn Header="Short Name"
                                                    Binding="{Binding ShortName}"
                                                    Width="1.2*" />

                                <DataGridTextColumn Header="Description"
                                                    Binding="{Binding Description}"
                                                    Width="2*" />

                                <DataGridTextColumn Header="Can Post"
                                                    Binding="{Binding CanPostText}"
                                                    Width="100" />

                                <DataGridTextColumn Header="Issues"
                                                    Binding="{Binding Issues}"
                                                    Width="2.5*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </TabItem>

            <TabItem  x:Name="FinalizeTab" Header="4. Finalize">
                <Border Margin="4"
                        Style="{StaticResource CardBorderStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="16" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="16" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock Text="Finalize Import"
                                   Style="{StaticResource TextBlock.SectionTitle}" />

                        <TextBox x:Name="FinalizeSummaryTextBox"
                                 Grid.Row="2"
                                 IsReadOnly="True"
                                 TextWrapping="Wrap" />

                        <TextBox x:Name="FinalizeMessagesTextBox"
                                 Grid.Row="4"
                                 IsReadOnly="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto" />
                    </Grid>
                </Border>
            </TabItem>
        </TabControl>

        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button x:Name="CancelButton"
                    Grid.Column="1"
                    MinWidth="100"
                    Padding="14,8"
                    Margin="0,0,8,0"
                    Click="CancelButton_Click">
                <TextBlock Text="Close" />
            </Button>

            <Button x:Name="PreviousButton"
                    Grid.Column="2"
                    MinWidth="100"
                    Padding="14,8"
                    Margin="0,0,8,0"
                    Click="PreviousButton_Click">
                <TextBlock Text="Previous" />
            </Button>

            <Button x:Name="NextButton"
                    Grid.Column="3"
                    MinWidth="100"
                    Padding="14,8"
                    Click="NextButton_Click">
                <TextBlock Text="Next" />
            </Button>
        </Grid>
    </Grid>
</Window>