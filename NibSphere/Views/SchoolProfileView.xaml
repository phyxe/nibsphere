<UserControl x:Class="NibSphere.Views.SchoolProfileView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:controls="clr-namespace:NibSphere.Controls"
             mc:Ignorable="d"
             d:DesignHeight="760"
             d:DesignWidth="1100"
             Background="{DynamicResource Brush.Background}">

    <UserControl.Resources>
        <Style x:Key="ProfileImageOverlayButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="{DynamicResource Brush.Surface}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder"
                                        Property="Background"
                                        Value="{DynamicResource Brush.IconButtonHoverBackground}" />
                                <Setter TargetName="ButtonBorder"
                                        Property="BorderBrush"
                                        Value="{DynamicResource Brush.PrimaryAccent}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder"
                                        Property="Background"
                                        Value="{DynamicResource Brush.IconButtonHoverBackground}" />
                                <Setter TargetName="ButtonBorder"
                                        Property="BorderBrush"
                                        Value="{DynamicResource Brush.PrimaryAccent}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.6" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="4">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="School Profile"
                       Style="{StaticResource TextBlock.Heading1}" />

            <Border Grid.Row="2"
                    Style="{StaticResource CardBorderStyle}">
                <StackPanel HorizontalAlignment="Center">
                    <Grid Width="132"
                          Height="132"
                          Margin="0,4,0,12">
                        <Ellipse x:Name="SchoolLogoEllipse"
                                 Width="132"
                                 Height="132"
                                 Stroke="{DynamicResource Brush.Border}"
                                 StrokeThickness="1"
                                 Fill="{DynamicResource Brush.SurfaceAlt}" />

                        <TextBlock x:Name="SchoolLogoInitialsTextBlock"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontSize="28"
                                   FontWeight="SemiBold"
                                   Style="{StaticResource TextBlock.Heading2}"
                                   Text="SCH" />

                        <StackPanel x:Name="SchoolLogoButtonsPanel"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Bottom"
                                    Margin="0,0,-4,-4">
                            <Button x:Name="BrowseSchoolLogoButton"
                                    Style="{StaticResource ProfileImageOverlayButtonStyle}"
                                    Margin="0,0,6,0"
                                    Click="BrowseSchoolLogoButton_Click"
                                    ToolTip="Upload Logo">
                                <controls:ControlSvgIcon Width="14"
                                                         Height="14"
                                                         Source="/Resources/Icons/upload.svg"
                                                         Tint="{DynamicResource Brush.PrimaryText}" />
                            </Button>

                            <Button x:Name="RemoveSchoolLogoButton"
                                    Style="{StaticResource ProfileImageOverlayButtonStyle}"
                                    Click="RemoveSchoolLogoButton_Click"
                                    ToolTip="Remove Logo">
                                <controls:ControlSvgIcon Width="14"
                                                         Height="14"
                                                         Source="/Resources/Icons/trash.svg"
                                                         Tint="{DynamicResource Brush.PrimaryText}" />
                            </Button>
                        </StackPanel>
                    </Grid>

                    <TextBlock x:Name="SchoolHeaderNameTextBlock"
                               Text="SCHOOL PROFILE"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               Style="{StaticResource TextBlock.Heading2}" />

                    <TextBlock x:Name="SchoolHeaderMetaTextBlock"
                               Margin="0,2,0,0"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               Style="{StaticResource TextBlock.Secondary}"
                               Text="" />
                </StackPanel>
            </Border>

            <Border Grid.Row="4"
                    Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="20"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="20"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="20"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="20"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="20"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="24"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="School Information"
                               Style="{StaticResource TextBlock.SectionTitle}" />

                    <!-- School identity -->
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2.2*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="1.2*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="School Name"
                                       Margin="0,0,0,6"
                                       Style="{StaticResource TextBlock.Body}" />
                            <TextBox x:Name="SchoolNameTextBox"
                                     MinHeight="36"
                                     TextChanged="SchoolFields_TextChanged" />
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="School ID"
                                       Margin="0,0,0,6"
                                       Style="{StaticResource TextBlock.Body}" />
                            <TextBox x:Name="SchoolIdTextBox"
                                     MinHeight="36" />
                        </StackPanel>

                        <StackPanel Grid.Column="4">
                            <TextBlock Text="School Acronym"
                                       Margin="0,0,0,6"
                                       Style="{StaticResource TextBlock.Body}" />
                            <TextBox x:Name="SchoolAcronymTextBox"
                                     MinHeight="36"
                                     TextChanged="SchoolFields_TextChanged" />
                        </StackPanel>
                    </Grid>

                    <!-- Administrative hierarchy -->
                    <Grid Grid.Row="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.1*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="1.4*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="1.1*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Region"
                                       Margin="0,0,0,6"
                                       Style="{StaticResource TextBlock.Body}" />
                            <TextBox x:Name="RegionTextBox"
                                     MinHeight="36" />
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Division"
                                       Margin="0,0,0,6"
                                       Style="{StaticResource TextBlock.Body}" />
                            <TextBox x:Name="DivisionTextBox"
                                     MinHeight="36" />
                        </StackPanel>

                        <StackPanel Grid.Column="4">
                            <TextBlock Text="District"
                                       Margin="0,0,0,6"
                                       Style="{StaticResource TextBlock.Body}" />
                            <TextBox x:Name="DistrictTextBox"
                                     MinHeight="36" />
                        </StackPanel>
                    </Grid>

                    <!-- Civil address selectors -->
                    <Grid Grid.Row="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.2*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="1.5*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="1.5*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Province / Region"
                                       Margin="0,0,0,6"
                                       Style="{StaticResource TextBlock.Body}" />
                            <ComboBox x:Name="TopLevelComboBox"
                                      MinHeight="36"
                                      DisplayMemberPath="Name"
                                      SelectedValuePath="Code"
                                      SelectionChanged="TopLevelComboBox_SelectionChanged" />
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Municipality / City"
                                       Margin="0,0,0,6"
                                       Style="{StaticResource TextBlock.Body}" />
                            <ComboBox x:Name="MunicipalityCityComboBox"
                                      MinHeight="36"
                                      DisplayMemberPath="Name"
                                      SelectedValuePath="Code"
                                      SelectionChanged="MunicipalityCityComboBox_SelectionChanged" />
                        </StackPanel>

                        <StackPanel Grid.Column="4">
                            <TextBlock Text="Barangay"
                                       Margin="0,0,0,6"
                                       Style="{StaticResource TextBlock.Body}" />
                            <ComboBox x:Name="BarangayComboBox"
                                      MinHeight="36"
                                      DisplayMemberPath="Name"
                                      SelectedValuePath="Code" />
                        </StackPanel>
                    </Grid>

                    <!-- Address line -->
                    <StackPanel Grid.Row="8">
                        <TextBlock Text="Address Line"
                                   Margin="0,0,0,6"
                                   Style="{StaticResource TextBlock.Body}" />
                        <TextBox x:Name="AddressLineTextBox"
                                 MinHeight="36" />
                    </StackPanel>

                    <!-- School head -->
                    <Grid Grid.Row="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.5*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="1.2*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="School Head"
                                       Margin="0,0,0,6"
                                       Style="{StaticResource TextBlock.Body}" />
                            <TextBox x:Name="SchoolHeadNameTextBox"
                                     MinHeight="36" />
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="School Head Position / Designation"
                                       Margin="0,0,0,6"
                                       Style="{StaticResource TextBlock.Body}" />
                            <TextBox x:Name="SchoolHeadPositionTextBox"
                                     MinHeight="36" />
                        </StackPanel>
                    </Grid>

                    <!-- Footer -->
                    <Grid Grid.Row="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock x:Name="SchoolLogoStatusTextBlock"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource TextBlock.Caption}"
                                   Visibility="Collapsed"
                                   Text="" />

                        <Button Grid.Column="1"
                                x:Name="SaveSchoolProfileButton"
                                Width="170"
                                HorizontalAlignment="Right"
                                Click="SaveSchoolProfileButton_Click">
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Center">
                                <controls:ControlSvgIcon x:Name="SaveSchoolProfileActionIcon"
                                                         Width="16"
                                                         Height="16"
                                                         Margin="0,0,8,0"
                                                         Source="/Resources/Icons/save.svg"
                                                         Tint="White" />
                                <TextBlock x:Name="SaveSchoolProfileActionTextBlock"
                                           VerticalAlignment="Center"
                                           Foreground="White"
                                           Text="Save School Profile" />
                            </StackPanel>
                        </Button>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>