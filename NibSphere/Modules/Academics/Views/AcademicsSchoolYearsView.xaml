<UserControl x:Class="NibSphere.Modules.Academics.Views.AcademicsSchoolYearsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="760"
             d:DesignWidth="1100"
             Background="{DynamicResource Brush.Background}">

    <Grid Margin="4">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="School Years"
                   Style="{StaticResource TextBlock.Heading1}" />

        <Grid Grid.Row="2">

            <!-- ========================================================= -->
            <!-- FLOW 1: SCHOOL YEAR LIST                                  -->
            <!-- ========================================================= -->
            <Border x:Name="SchoolYearListPanel"
                    Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="Saved School Years"
                                       Style="{StaticResource TextBlock.SectionTitle}" />

                            <TextBlock Margin="0,4,0,0"
                                       Text="Create a school year, then open it to manage its terms."
                                       Style="{StaticResource TextBlock.Secondary}" />
                        </StackPanel>

                        <Button Grid.Column="1"
                                MinWidth="112"
                                MinHeight="32"
                                Margin="16,0,0,0"
                                Padding="10,4"
                                Content="New School Year"
                                Click="NewSchoolYearButton_Click" />
                    </Grid>

                    <TextBlock x:Name="EmptySchoolYearsTextBlock"
                               Grid.Row="2"
                               Text="No school years yet. Create the present school year to begin."
                               Style="{StaticResource TextBlock.Secondary}"
                               Visibility="Collapsed" />

                    <ScrollViewer Grid.Row="2"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl x:Name="SchoolYearsItemsControl">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,12"
                                            Padding="14"
                                            Style="{StaticResource CardBorderStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel>
                                                <TextBlock Text="{Binding Name}"
                                                           FontWeight="SemiBold"
                                                           Style="{StaticResource TextBlock.Body}" />

                                                <TextBlock Margin="0,6,0,0"
                                                           Text="{Binding DateRangeDisplay}"
                                                           Style="{StaticResource TextBlock.Secondary}" />

                                                <TextBlock Margin="0,6,0,0"
                                                           Text="{Binding TermSummaryDisplay}"
                                                           Style="{StaticResource TextBlock.Secondary}" />

                                                <TextBlock Margin="0,6,0,0"
                                                           Text="{Binding StatusDisplay}"
                                                           Style="{StaticResource TextBlock.Secondary}" />
                                            </StackPanel>

                                            <Button Grid.Column="1"
                                                    MinWidth="76"
                                                    MinHeight="32"
                                                    Margin="16,0,0,0"
                                                    Padding="10,4"
                                                    VerticalAlignment="Center"
                                                    Content="Open"
                                                    Tag="{Binding}"
                                                    Click="OpenSchoolYearButton_Click" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- ========================================================= -->
            <!-- FLOW 2: SCHOOL YEAR OVERVIEW                              -->
            <!-- ========================================================= -->
            <Border x:Name="SchoolYearOverviewPanel"
                    Style="{StaticResource CardBorderStyle}"
                    Visibility="Collapsed">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock x:Name="OverviewTitleTextBlock"
                                           Text="School Year"
                                           Style="{StaticResource TextBlock.SectionTitle}" />

                                <TextBlock x:Name="OverviewSubtitleTextBlock"
                                           Margin="0,4,0,0"
                                           Text="Review this school year and manage its terms."
                                           Style="{StaticResource TextBlock.Secondary}" />
                            </StackPanel>

                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Right">
                                <Button MinWidth="76"
                                        MinHeight="32"
                                        Margin="0,0,8,0"
                                        Padding="10,4"
                                        Content="Back"
                                        Click="BackToListButton_Click" />

                                <Button MinWidth="112"
                                        MinHeight="32"
                                        Padding="10,4"
                                        Content="Edit School Year"
                                        Click="EditSchoolYearButton_Click" />
                            </StackPanel>
                        </Grid>

                        <Border Margin="0,18,0,0"
                                Padding="14"
                                Style="{StaticResource CardBorderStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="10"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Row="0"
                                            Grid.Column="0">
                                    <TextBlock Text="Date Range"
                                               Style="{StaticResource TextBlock.Secondary}" />

                                    <TextBlock x:Name="OverviewDateRangeTextBlock"
                                               Margin="0,4,0,0"
                                               Style="{StaticResource TextBlock.Body}" />
                                </StackPanel>

                                <StackPanel Grid.Row="0"
                                            Grid.Column="1">
                                    <TextBlock Text="Terms"
                                               Style="{StaticResource TextBlock.Secondary}" />

                                    <TextBlock x:Name="OverviewTermCountTextBlock"
                                               Margin="0,4,0,0"
                                               Style="{StaticResource TextBlock.Body}" />
                                </StackPanel>

                                <StackPanel Grid.Row="0"
                                            Grid.Column="2">
                                    <TextBlock Text="Status"
                                               Style="{StaticResource TextBlock.Secondary}" />

                                    <TextBlock x:Name="OverviewStatusTextBlock"
                                               Margin="0,4,0,0"
                                               Style="{StaticResource TextBlock.Body}" />
                                </StackPanel>

                                <TextBlock x:Name="OverviewDependencyTextBlock"
                                           Grid.Row="2"
                                           Grid.Column="0"
                                           Grid.ColumnSpan="3"
                                           Style="{StaticResource TextBlock.Secondary}" />
                            </Grid>
                        </Border>

                        <Grid Margin="0,22,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Text="Terms"
                                           Style="{StaticResource TextBlock.SectionTitle}" />

                                <TextBlock Margin="0,4,0,0"
                                           Text="Parent terms may serve as broader containers; child terms may serve as grading or reporting slices."
                                           Style="{StaticResource TextBlock.Secondary}" />
                            </StackPanel>

                            <Button Grid.Column="1"
                                    MinWidth="96"
                                    MinHeight="32"
                                    Margin="16,0,0,0"
                                    Padding="10,4"
                                    Content="Add Term"
                                    Click="AddTermButton_Click" />
                        </Grid>

                        <TextBlock x:Name="EmptyTermsTextBlock"
                                   Margin="0,16,0,0"
                                   Text="No terms yet. Add a parent term, semester, trimester, quarter, or other school-year term."
                                   Style="{StaticResource TextBlock.Secondary}"
                                   Visibility="Collapsed" />

                        <ItemsControl x:Name="TermsItemsControl"
                                      Margin="0,16,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,12"
                                            Padding="14"
                                            Style="{StaticResource CardBorderStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel>
                                                <TextBlock Text="{Binding HeaderDisplay}"
                                                           FontWeight="SemiBold"
                                                           Style="{StaticResource TextBlock.Body}" />

                                                <TextBlock Margin="0,6,0,0"
                                                           Text="{Binding DateRangeDisplay}"
                                                           Style="{StaticResource TextBlock.Secondary}" />

                                                <TextBlock Margin="0,6,0,0"
                                                           Text="{Binding DetailDisplay}"
                                                           Style="{StaticResource TextBlock.Secondary}" />
                                            </StackPanel>

                                            <StackPanel Grid.Column="1"
                                                        Orientation="Horizontal"
                                                        VerticalAlignment="Center"
                                                        Margin="16,0,0,0">
                                                <Button MinWidth="72"
                                                        MinHeight="32"
                                                        Margin="0,0,8,0"
                                                        Padding="10,4"
                                                        Content="Edit"
                                                        Tag="{Binding}"
                                                        Click="EditTermButton_Click" />

                                                <Button MinWidth="72"
                                                        MinHeight="32"
                                                        Padding="10,4"
                                                        Content="Delete"
                                                        Tag="{Binding}"
                                                        Click="DeleteTermButton_Click" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Button x:Name="DeleteSchoolYearButton"
                                MinWidth="124"
                                MinHeight="32"
                                Margin="0,18,0,0"
                                Padding="10,4"
                                HorizontalAlignment="Left"
                                Content="Delete School Year"
                                Click="DeleteSchoolYearButton_Click" />
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- ========================================================= -->
            <!-- FLOW 3: SCHOOL YEAR EDITOR                                -->
            <!-- ========================================================= -->
            <Border x:Name="SchoolYearEditorPanel"
                    Style="{StaticResource CardBorderStyle}"
                    Visibility="Collapsed">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <TextBlock x:Name="SchoolYearEditorTitleTextBlock"
                                   Text="New School Year"
                                   Style="{StaticResource TextBlock.SectionTitle}" />

                        <TextBlock Margin="0,4,0,18"
                                   Text="Set the name and official date range before adding terms."
                                   Style="{StaticResource TextBlock.Secondary}" />

                        <Border Padding="14"
                                Style="{StaticResource CardBorderStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="14"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="14"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="130"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="130"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Label Grid.Row="0"
                                       Grid.Column="0"
                                       Content="Name"
                                       VerticalAlignment="Center" />

                                <TextBox x:Name="SchoolYearNameTextBox"
                                         Grid.Row="0"
                                         Grid.Column="1"
                                         Grid.ColumnSpan="4"
                                         MinHeight="34"
                                         VerticalContentAlignment="Center" />

                                <Label Grid.Row="2"
                                       Grid.Column="0"
                                       Content="Start Date"
                                       VerticalAlignment="Center" />

                                <DatePicker x:Name="SchoolYearStartDatePicker"
                                            Grid.Row="2"
                                            Grid.Column="1"
                                            MinHeight="34"
                                            VerticalContentAlignment="Center" />

                                <Label Grid.Row="2"
                                       Grid.Column="3"
                                       Content="End Date"
                                       VerticalAlignment="Center" />

                                <DatePicker x:Name="SchoolYearEndDatePicker"
                                            Grid.Row="2"
                                            Grid.Column="4"
                                            MinHeight="34"
                                            VerticalContentAlignment="Center" />

                                <StackPanel Grid.Row="4"
                                            Grid.Column="1"
                                            Grid.ColumnSpan="4"
                                            Orientation="Horizontal">
                                    <CheckBox x:Name="SchoolYearIsCurrentCheckBox"
                                              Margin="0,0,24,0"
                                              Content="Current school year"
                                              VerticalAlignment="Center" />

                                    <CheckBox x:Name="SchoolYearIsActiveCheckBox"
                                              Content="Active"
                                              VerticalAlignment="Center" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <StackPanel Margin="0,18,0,0"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right">
                            <Button MinWidth="84"
                                    MinHeight="32"
                                    Margin="0,0,8,0"
                                    Padding="10,4"
                                    Content="Save"
                                    Click="SaveSchoolYearButton_Click" />

                            <Button MinWidth="84"
                                    MinHeight="32"
                                    Padding="10,4"
                                    Content="Cancel"
                                    Click="CancelSchoolYearEditorButton_Click" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- ========================================================= -->
            <!-- FLOW 4: TERM EDITOR                                       -->
            <!-- ========================================================= -->
            <Border x:Name="TermEditorPanel"
                    Style="{StaticResource CardBorderStyle}"
                    Visibility="Collapsed">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <TextBlock x:Name="TermEditorTitleTextBlock"
                                   Text="Add Term"
                                   Style="{StaticResource TextBlock.SectionTitle}" />

                        <TextBlock Margin="0,4,0,18"
                                   Text="Define one term under the selected school year."
                                   Style="{StaticResource TextBlock.Secondary}" />

                        <Border Padding="14"
                                Style="{StaticResource CardBorderStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="14"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="14"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="14"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="14"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="130"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="130"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Label Grid.Row="0"
                                       Grid.Column="0"
                                       Content="Name"
                                       VerticalAlignment="Center" />

                                <TextBox x:Name="TermNameTextBox"
                                         Grid.Row="0"
                                         Grid.Column="1"
                                         MinHeight="34"
                                         VerticalContentAlignment="Center" />

                                <Label Grid.Row="0"
                                       Grid.Column="3"
                                       Content="Short Name"
                                       VerticalAlignment="Center" />

                                <TextBox x:Name="TermShortNameTextBox"
                                         Grid.Row="0"
                                         Grid.Column="4"
                                         MinHeight="34"
                                         VerticalContentAlignment="Center" />

                                <Label Grid.Row="2"
                                       Grid.Column="0"
                                       Content="Start Date"
                                       VerticalAlignment="Center" />

                                <DatePicker x:Name="TermStartDatePicker"
                                            Grid.Row="2"
                                            Grid.Column="1"
                                            MinHeight="34"
                                            VerticalContentAlignment="Center" />

                                <Label Grid.Row="2"
                                       Grid.Column="3"
                                       Content="End Date"
                                       VerticalAlignment="Center" />

                                <DatePicker x:Name="TermEndDatePicker"
                                            Grid.Row="2"
                                            Grid.Column="4"
                                            MinHeight="34"
                                            VerticalContentAlignment="Center" />

                                <Label Grid.Row="4"
                                       Grid.Column="0"
                                       Content="Term Type"
                                       VerticalAlignment="Center" />

                                <CheckBox x:Name="TermIsParentTermCheckBox"
                                          Grid.Row="4"
                                          Grid.Column="1"
                                          Grid.ColumnSpan="4"
                                          Content="This is a parent term"
                                          VerticalAlignment="Center"
                                          Checked="TermIsParentTermCheckBox_Changed"
                                          Unchecked="TermIsParentTermCheckBox_Changed" />

                                <StackPanel x:Name="ParentTermPanel"
                                            Grid.Row="6"
                                            Grid.Column="0"
                                            Grid.ColumnSpan="5"
                                            Visibility="Collapsed">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="130"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <Label Grid.Column="0"
                                               Content="Parent Term"
                                               VerticalAlignment="Center" />

                                        <ComboBox x:Name="ParentTermComboBox"
                                                  Grid.Column="1"
                                                  MinHeight="34"
                                                  DisplayMemberPath="DisplayName"
                                                  SelectedValuePath="Id"
                                                  VerticalContentAlignment="Center" />
                                    </Grid>
                                </StackPanel>

                                <Label Grid.Row="8"
                                       Grid.Column="0"
                                       Content="Sort Order"
                                       VerticalAlignment="Center" />

                                <TextBox x:Name="TermSortOrderTextBox"
                                         Grid.Row="8"
                                         Grid.Column="1"
                                         MinHeight="34"
                                         VerticalContentAlignment="Center" />

                                <StackPanel Grid.Row="8"
                                            Grid.Column="3"
                                            Grid.ColumnSpan="2"
                                            Orientation="Horizontal"
                                            HorizontalAlignment="Left">
                                    <CheckBox x:Name="TermIsEnrollmentCheckBox"
                                              Margin="0,0,14,0"
                                              Content="Enrollment"
                                              VerticalAlignment="Center" />

                                    <CheckBox x:Name="TermIsGradingCheckBox"
                                              Margin="0,0,14,0"
                                              Content="Grading"
                                              VerticalAlignment="Center" />

                                    <CheckBox x:Name="TermIsReportingCheckBox"
                                              Margin="0,0,14,0"
                                              Content="Reporting"
                                              VerticalAlignment="Center" />

                                    <CheckBox x:Name="TermIsActiveCheckBox"
                                              Content="Active"
                                              VerticalAlignment="Center" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <StackPanel Margin="0,18,0,0"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right">
                            <Button MinWidth="84"
                                    MinHeight="32"
                                    Margin="0,0,8,0"
                                    Padding="10,4"
                                    Content="Save"
                                    Click="SaveTermButton_Click" />

                            <Button MinWidth="84"
                                    MinHeight="32"
                                    Padding="10,4"
                                    Content="Cancel"
                                    Click="CancelTermButton_Click" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>

        </Grid>
    </Grid>
</UserControl>