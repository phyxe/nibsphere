<UserControl x:Class="NibSphere.Modules.Academics.Views.AcademicsSchoolYearsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="760"
             d:DesignWidth="1100"
             Background="{DynamicResource Brush.Background}">

    <Grid Margin="4">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="School Years"
                   Style="{StaticResource TextBlock.Heading1}" />

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="340"
                                  MinWidth="300"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"
                                  MinWidth="560"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT: School Year Card List -->
            <Border Grid.Column="0"
                    Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Saved School Years"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource TextBlock.SectionTitle}" />

                        <Button x:Name="NewSchoolYearButton"
                                Grid.Column="1"
                                MinWidth="96"
                                Height="40"
                                Margin="12,0,0,0"
                                Padding="14,0"
                                Content="New"
                                Click="NewSchoolYearButton_Click" />
                    </Grid>

                    <ScrollViewer Grid.Row="2"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl x:Name="SchoolYearsItemsControl">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,12"
                                            Padding="14"
                                            Cursor="Hand"
                                            Tag="{Binding}"
                                            Style="{StaticResource CardBorderStyle}"
                                            MouseLeftButtonUp="SchoolYearCard_MouseLeftButtonUp">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}"
                                                       FontWeight="SemiBold"
                                                       TextWrapping="Wrap"
                                                       Style="{StaticResource TextBlock.Body}" />

                                            <TextBlock Margin="0,8,0,0"
                                                       Text="{Binding DateRangeDisplay}"
                                                       TextWrapping="Wrap"
                                                       Style="{StaticResource TextBlock.Body}" />

                                            <TextBlock Margin="0,6,0,0"
                                                       Text="{Binding TermSummaryDisplay}"
                                                       Style="{StaticResource TextBlock.Body}" />

                                            <TextBlock Margin="0,6,0,0"
                                                       Text="{Binding StatusDisplay}"
                                                       TextWrapping="Wrap"
                                                       Style="{StaticResource TextBlock.Body}" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- RIGHT: Selected School Year Workspace -->
            <Border Grid.Column="2"
                    Style="{StaticResource CardBorderStyle}">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>

                        <!-- Header and school year commands -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock x:Name="SelectedSchoolYearTitleTextBlock"
                                       Text="Select or create a school year"
                                       VerticalAlignment="Center"
                                       TextWrapping="Wrap"
                                       Style="{StaticResource TextBlock.SectionTitle}" />

                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Right">
                                <Button x:Name="SaveSchoolYearButton"
                                        MinWidth="128"
                                        Height="40"
                                        Margin="12,0,0,0"
                                        Padding="14,0"
                                        Content="Save"
                                        Click="SaveSchoolYearButton_Click" />

                                <Button x:Name="DeleteSchoolYearButton"
                                        MinWidth="128"
                                        Height="40"
                                        Margin="8,0,0,0"
                                        Padding="14,0"
                                        Content="Delete"
                                        Click="DeleteSchoolYearButton_Click" />
                            </StackPanel>
                        </Grid>

                        <!-- School year editor -->
                        <Border Margin="0,18,0,0"
                                Padding="14"
                                Style="{StaticResource CardBorderStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="12"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="12"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Row="0"
                                           Grid.Column="0"
                                           Text="Name"
                                           VerticalAlignment="Center"
                                           Style="{StaticResource TextBlock.Body}" />

                                <TextBox x:Name="SchoolYearNameTextBox"
                                         Grid.Row="0"
                                         Grid.Column="1"
                                         Grid.ColumnSpan="4"
                                         MinHeight="36"
                                         VerticalContentAlignment="Center" />

                                <TextBlock Grid.Row="2"
                                           Grid.Column="0"
                                           Text="Start Date"
                                           VerticalAlignment="Center"
                                           Style="{StaticResource TextBlock.Body}" />

                                <DatePicker x:Name="SchoolYearStartDatePicker"
                                            Grid.Row="2"
                                            Grid.Column="1"
                                            MinHeight="36"
                                            VerticalContentAlignment="Center" />

                                <TextBlock Grid.Row="2"
                                           Grid.Column="3"
                                           Text="End Date"
                                           VerticalAlignment="Center"
                                           Style="{StaticResource TextBlock.Body}" />

                                <DatePicker x:Name="SchoolYearEndDatePicker"
                                            Grid.Row="2"
                                            Grid.Column="4"
                                            MinHeight="36"
                                            VerticalContentAlignment="Center" />

                                <StackPanel Grid.Row="4"
                                            Grid.Column="1"
                                            Grid.ColumnSpan="4"
                                            Orientation="Horizontal">
                                    <CheckBox x:Name="SchoolYearIsCurrentCheckBox"
                                              Margin="0,0,24,0"
                                              VerticalAlignment="Center"
                                              Content="Current school year" />

                                    <CheckBox x:Name="SchoolYearIsActiveCheckBox"
                                              VerticalAlignment="Center"
                                              Content="Active" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Terms heading -->
                        <Grid Margin="0,22,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Terms under this school year"
                                       VerticalAlignment="Center"
                                       Style="{StaticResource TextBlock.SectionTitle}" />

                            <Button x:Name="AddTermButton"
                                    Grid.Column="1"
                                    MinWidth="120"
                                    Height="40"
                                    Padding="14,0"
                                    Content="Add Term"
                                    Click="AddTermButton_Click" />
                        </Grid>

                        <!-- Term editor -->
                        <Border x:Name="TermEditorBorder"
                                Margin="0,14,0,0"
                                Padding="14"
                                Visibility="Collapsed"
                                Style="{StaticResource CardBorderStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="14"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="12"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="12"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="14"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock x:Name="TermEditorTitleTextBlock"
                                           Grid.Row="0"
                                           Grid.Column="0"
                                           Grid.ColumnSpan="5"
                                           Text="Add Term"
                                           Style="{StaticResource TextBlock.SectionTitle}" />

                                <TextBlock Grid.Row="2"
                                           Grid.Column="0"
                                           Text="Name"
                                           VerticalAlignment="Center"
                                           Style="{StaticResource TextBlock.Body}" />

                                <TextBox x:Name="TermNameTextBox"
                                         Grid.Row="2"
                                         Grid.Column="1"
                                         MinHeight="36"
                                         VerticalContentAlignment="Center" />

                                <TextBlock Grid.Row="2"
                                           Grid.Column="3"
                                           Text="Short Name"
                                           VerticalAlignment="Center"
                                           Style="{StaticResource TextBlock.Body}" />

                                <TextBox x:Name="TermShortNameTextBox"
                                         Grid.Row="2"
                                         Grid.Column="4"
                                         MinHeight="36"
                                         VerticalContentAlignment="Center" />

                                <TextBlock Grid.Row="4"
                                           Grid.Column="0"
                                           Text="Start Date"
                                           VerticalAlignment="Center"
                                           Style="{StaticResource TextBlock.Body}" />

                                <DatePicker x:Name="TermStartDatePicker"
                                            Grid.Row="4"
                                            Grid.Column="1"
                                            MinHeight="36"
                                            VerticalContentAlignment="Center" />

                                <TextBlock Grid.Row="4"
                                           Grid.Column="3"
                                           Text="End Date"
                                           VerticalAlignment="Center"
                                           Style="{StaticResource TextBlock.Body}" />

                                <DatePicker x:Name="TermEndDatePicker"
                                            Grid.Row="4"
                                            Grid.Column="4"
                                            MinHeight="36"
                                            VerticalContentAlignment="Center" />

                                <TextBlock Grid.Row="6"
                                           Grid.Column="0"
                                           Text="Parent Term"
                                           VerticalAlignment="Center"
                                           Style="{StaticResource TextBlock.Body}" />

                                <ComboBox x:Name="ParentTermComboBox"
                                          Grid.Row="6"
                                          Grid.Column="1"
                                          MinHeight="36"
                                          DisplayMemberPath="DisplayName"
                                          SelectedValuePath="Id"
                                          VerticalContentAlignment="Center" />

                                <TextBlock Grid.Row="6"
                                           Grid.Column="3"
                                           Text="Sort Order"
                                           VerticalAlignment="Center"
                                           Style="{StaticResource TextBlock.Body}" />

                                <TextBox x:Name="TermSortOrderTextBox"
                                         Grid.Row="6"
                                         Grid.Column="4"
                                         MinHeight="36"
                                         VerticalContentAlignment="Center" />

                                <StackPanel Grid.Row="8"
                                            Grid.Column="0"
                                            Grid.ColumnSpan="3"
                                            Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <CheckBox x:Name="TermIsEnrollmentCheckBox"
                                              Margin="0,0,18,0"
                                              Content="Enrollment" />

                                    <CheckBox x:Name="TermIsGradingCheckBox"
                                              Margin="0,0,18,0"
                                              Content="Grading" />

                                    <CheckBox x:Name="TermIsReportingCheckBox"
                                              Margin="0,0,18,0"
                                              Content="Reporting" />

                                    <CheckBox x:Name="TermIsActiveCheckBox"
                                              Content="Active" />
                                </StackPanel>

                                <StackPanel Grid.Row="8"
                                            Grid.Column="4"
                                            Orientation="Horizontal"
                                            HorizontalAlignment="Right">
                                    <Button MinWidth="104"
                                            Height="40"
                                            Margin="0,0,8,0"
                                            Padding="14,0"
                                            Content="Save"
                                            Click="SaveTermButton_Click" />

                                    <Button MinWidth="104"
                                            Height="40"
                                            Padding="14,0"
                                            Content="Cancel"
                                            Click="CancelTermButton_Click" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Term accordion cards -->
                        <ItemsControl x:Name="TermsItemsControl"
                                      Margin="0,14,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Expander Margin="0,0,0,12"
                                              Header="{Binding HeaderDisplay}"
                                              IsExpanded="False">
                                        <Border Padding="14"
                                                Style="{StaticResource CardBorderStyle}">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="10"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="10"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="14"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="120"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="20"/>
                                                    <ColumnDefinition Width="120"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Grid.Row="0"
                                                           Grid.Column="0"
                                                           Text="Name"
                                                           Style="{StaticResource TextBlock.Body}" />

                                                <TextBlock Grid.Row="0"
                                                           Grid.Column="1"
                                                           Text="{Binding Name}"
                                                           TextWrapping="Wrap"
                                                           Style="{StaticResource TextBlock.Body}" />

                                                <TextBlock Grid.Row="0"
                                                           Grid.Column="3"
                                                           Text="Short Name"
                                                           Style="{StaticResource TextBlock.Body}" />

                                                <TextBlock Grid.Row="0"
                                                           Grid.Column="4"
                                                           Text="{Binding ShortName}"
                                                           TextWrapping="Wrap"
                                                           Style="{StaticResource TextBlock.Body}" />

                                                <TextBlock Grid.Row="2"
                                                           Grid.Column="0"
                                                           Text="Dates"
                                                           Style="{StaticResource TextBlock.Body}" />

                                                <TextBlock Grid.Row="2"
                                                           Grid.Column="1"
                                                           Text="{Binding DateRangeDisplay}"
                                                           TextWrapping="Wrap"
                                                           Style="{StaticResource TextBlock.Body}" />

                                                <TextBlock Grid.Row="2"
                                                           Grid.Column="3"
                                                           Text="Scope"
                                                           Style="{StaticResource TextBlock.Body}" />

                                                <TextBlock Grid.Row="2"
                                                           Grid.Column="4"
                                                           Text="{Binding TermScope}"
                                                           TextWrapping="Wrap"
                                                           Style="{StaticResource TextBlock.Body}" />

                                                <TextBlock Grid.Row="4"
                                                           Grid.Column="0"
                                                           Text="Use"
                                                           Style="{StaticResource TextBlock.Body}" />

                                                <TextBlock Grid.Row="4"
                                                           Grid.Column="1"
                                                           Grid.ColumnSpan="4"
                                                           Text="{Binding UsageDisplay}"
                                                           TextWrapping="Wrap"
                                                           Style="{StaticResource TextBlock.Body}" />

                                                <StackPanel Grid.Row="6"
                                                            Grid.Column="0"
                                                            Grid.ColumnSpan="5"
                                                            Orientation="Horizontal"
                                                            HorizontalAlignment="Right">
                                                    <Button MinWidth="96"
                                                            Height="40"
                                                            Margin="0,0,8,0"
                                                            Padding="14,0"
                                                            Content="Edit"
                                                            Tag="{Binding}"
                                                            Click="EditTermButton_Click" />

                                                    <Button MinWidth="96"
                                                            Height="40"
                                                            Padding="14,0"
                                                            Content="Delete"
                                                            Tag="{Binding}"
                                                            Click="DeleteTermButton_Click" />
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </Expander>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</UserControl>