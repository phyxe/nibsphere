<Window x:Class="NibSphere.Modules.Learners.Windows.LearnersImportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        mc:Ignorable="d"
        Title="Import Learners"
        Width="920"
        Height="660"
        MinWidth="820"
        MinHeight="560"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="CanResize"
        StateChanged="LearnersImportWindow_StateChanged"
        Background="{DynamicResource Brush.Background}">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="40"
                            ResizeBorderThickness="6"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <Style x:Key="TitleBarButtonStyle" TargetType="Button">
            <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True" />
            <Setter Property="Width" Value="46" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.TitleBarForeground}" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder"
                                        Property="Background"
                                        Value="{DynamicResource Brush.TitleBarButtonHoverBackground}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder"
                                        Property="Background"
                                        Value="{DynamicResource Brush.TitleBarButtonHoverBackground}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TitleBarCloseButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource TitleBarButtonStyle}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="White" />
                                <Setter TargetName="ButtonBorder"
                                        Property="Background"
                                        Value="{DynamicResource Brush.TitleBarCloseButtonHoverBackground}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Foreground" Value="White" />
                                <Setter TargetName="ButtonBorder"
                                        Property="Background"
                                        Value="{DynamicResource Brush.TitleBarCloseButtonHoverBackground}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border x:Name="WindowBorder"
            BorderBrush="{DynamicResource Brush.Border}"
            BorderThickness="1"
            Background="{DynamicResource Brush.Background}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{DynamicResource Brush.TitleBarBackground}"
                    BorderBrush="{DynamicResource Brush.Border}"
                    BorderThickness="0,0,0,1">
                <Grid Height="40">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="46" />
                        <ColumnDefinition Width="46" />
                        <ColumnDefinition Width="46" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Margin="12,0,0,0"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource Brush.TitleBarForeground}"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Text="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=Title}" />

                    <Button Grid.Column="1"
                            Style="{StaticResource TitleBarButtonStyle}"
                            Click="MinimizeButton_Click">
                        <TextBlock Text="&#xE921;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="10"
                                   Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                    </Button>

                    <Button Grid.Column="2"
                            Style="{StaticResource TitleBarButtonStyle}"
                            Click="MaximizeRestoreButton_Click">
                        <TextBlock x:Name="MaximizeRestoreGlyph"
                                   Text="&#xE922;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="10"
                                   Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                    </Button>

                    <Button Grid.Column="3"
                            Style="{StaticResource TitleBarCloseButtonStyle}"
                            Click="CloseButton_Click">
                        <TextBlock Text="&#xE8BB;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="10"
                                   Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                    </Button>
                </Grid>
            </Border>

            <Grid Grid.Row="1"
                    Margin="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock x:Name="StepTitleTextBlock"
               Text="Import Learners"
               Style="{StaticResource TextBlock.Heading2}" />

                <TextBlock x:Name="StepDescriptionTextBlock"
               Grid.Row="2"
               TextWrapping="Wrap"
               Style="{StaticResource TextBlock.Body}" />

                <Grid Grid.Row="4">
                    <Border x:Name="SourceStepPanel"
                Style="{StaticResource CardBorderStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="12" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="12" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="12" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <TextBlock Text="Source File"
                           Style="{StaticResource TextBlock.SectionTitle}" />

                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBox x:Name="SelectedFilePathTextBox"
                             Height="36"
                             IsReadOnly="True"
                             VerticalContentAlignment="Center" />

                                <Button x:Name="BrowseFileButton"
                            Grid.Column="2"
                            Width="120"
                            Height="36"
                            Content="Browse..."
                            Click="BrowseFileButton_Click" />
                            </Grid>

                            <Grid Grid.Row="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="24" />
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="Detected File Type"
                               VerticalAlignment="Center"
                               Style="{StaticResource TextBlock.Body}" />

                                <TextBox x:Name="DetectedFileTypeTextBox"
                             Grid.Column="1"
                             Height="36"
                             IsReadOnly="True"
                             VerticalContentAlignment="Center" />

                                <TextBlock Grid.Column="3"
                               Text="Sheet"
                               VerticalAlignment="Center"
                               Style="{StaticResource TextBlock.Body}" />

                                <ComboBox x:Name="SheetComboBox"
                              Grid.Column="4"
                              Height="36"
                              DisplayMemberPath="Name"
                              SelectionChanged="SheetComboBox_SelectionChanged" />
                            </Grid>

                            <TextBox x:Name="SourceInfoTextBox"
                         Grid.Row="6"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto" />
                        </Grid>
                    </Border>

                    <Border x:Name="MappingStepPanel"
                Visibility="Collapsed"
                Style="{StaticResource CardBorderStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="12" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="12" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <TextBlock Text="Learner Field Mapping"
                           Style="{StaticResource TextBlock.SectionTitle}" />

                            <TextBlock Grid.Row="2"
                           Text="Map learner columns first. Custodian mapping will be added in the next slice."
                           TextWrapping="Wrap"
                           Style="{StaticResource TextBlock.Body}" />

                            <DataGrid x:Name="LearnerMappingsDataGrid"
                          Grid.Row="4"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          HeadersVisibility="Column"
                          IsReadOnly="False"
                          RowHeaderWidth="0"
                          MinHeight="280"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                          ScrollViewer.HorizontalScrollBarVisibility="Auto">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Field"
                                            Binding="{Binding FieldLabel}"
                                            IsReadOnly="True"
                                            Width="2*" />

                                    <DataGridTextColumn Header="Required"
                                            Binding="{Binding RequiredText}"
                                            IsReadOnly="True"
                                            Width="100" />

                                    <DataGridTemplateColumn Header="Source Column"
                                                Width="3*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <ComboBox ItemsSource="{Binding AvailableHeaders}"
                                              SelectedItem="{Binding SelectedSourceColumnHeader, UpdateSourceTrigger=PropertyChanged}"
                                              MinWidth="220" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>

                    <Border x:Name="PreviewStepPanel"
        Visibility="Collapsed"
        Style="{StaticResource CardBorderStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="12" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="12" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <TextBlock Text="Import Preview"
                   Style="{StaticResource TextBlock.SectionTitle}" />

                            <TextBox x:Name="PreviewSummaryTextBox"
                 Grid.Row="2"
                 IsReadOnly="True"
                 TextWrapping="Wrap"
                 AcceptsReturn="True"
                 VerticalScrollBarVisibility="Auto"
                 MinHeight="90" />

                            <DataGrid x:Name="PreviewRowsDataGrid"
                  Grid.Row="4"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  HeadersVisibility="Column"
                  IsReadOnly="True"
                  RowHeaderWidth="0"
                  MinHeight="280"
                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                  ScrollViewer.HorizontalScrollBarVisibility="Auto">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Row"
                                    Binding="{Binding SourceRowNumber}"
                                    Width="80" />

                                    <DataGridTextColumn Header="LRN"
                                    Binding="{Binding Lrn}"
                                    Width="140" />

                                    <DataGridTextColumn Header="Learner"
                                    Binding="{Binding LearnerName}"
                                    Width="2*" />

                                    <DataGridTextColumn Header="Can Import"
                                    Binding="{Binding CanImportText}"
                                    Width="100" />

                                    <DataGridTextColumn Header="Duplicate"
                                    Binding="{Binding DuplicateText}"
                                    Width="100" />

                                    <DataGridTextColumn Header="Errors"
                                    Binding="{Binding Errors}"
                                    Width="2.5*" />

                                    <DataGridTextColumn Header="Warnings"
                                    Binding="{Binding Warnings}"
                                    Width="2.5*" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>

                    <Border x:Name="ResultStepPanel"
        Visibility="Collapsed"
        Style="{StaticResource CardBorderStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="12" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="12" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <TextBlock Text="Import Result"
                   Style="{StaticResource TextBlock.SectionTitle}" />

                            <TextBox x:Name="ResultSummaryTextBox"
                 Grid.Row="2"
                 IsReadOnly="True"
                 TextWrapping="Wrap"
                 AcceptsReturn="True"
                 VerticalScrollBarVisibility="Auto"
                 MinHeight="90" />

                            <TextBox x:Name="ResultMessagesTextBox"
                 Grid.Row="4"
                 IsReadOnly="True"
                 TextWrapping="Wrap"
                 AcceptsReturn="True"
                 VerticalScrollBarVisibility="Auto" />
                        </Grid>
                    </Border>
                </Grid>

                <StackPanel Grid.Row="6"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                    <Button x:Name="PreviousButton"
                        Width="100"
                        Height="36"
                        Margin="0,0,8,0"
                        Content="Previous"
                        Visibility="Collapsed"
                        Click="PreviousButton_Click" />

                    <Button x:Name="CloseActionButton"
                        Width="100"
                        Height="36"
                        Margin="0,0,8,0"
                        Content="Close"
                        Click="CloseButton_Click" />

                    <Button x:Name="NextButton"
                        Width="100"
                        Height="36"
                        Content="Next"
                        Click="NextButton_Click" />
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>