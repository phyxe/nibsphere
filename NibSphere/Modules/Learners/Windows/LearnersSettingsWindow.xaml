                                                   Style="{StaticResource TextBlock.Secondary}" />

                                        <TextBox x:Name="ReligiousAffiliationBulkTextBox"
                                                 Grid.Row="4"
                                                 MinHeight="180"
                                                 AcceptsReturn="True"
                                                 TextWrapping="Wrap"
                                                 VerticalScrollBarVisibility="Auto" />

                                        <StackPanel Grid.Row="6" Orientation="Horizontal">
                                            <Button x:Name="AddReligiousAffiliationsButton"
                                                    MinWidth="120"
                                                    Padding="14,8"
                                                    Click="AddReligiousAffiliationsButton_Click">
                                                <TextBlock Text="Add Lines" />
                                            </Button>

                                            <Button x:Name="ClearReligiousAffiliationBulkButton"
                                                    MinWidth="90"
                                                    Padding="14,8"
                                                    Margin="8,0,0,0"
                                                    Click="ClearReligiousAffiliationBulkButton_Click">
                                                <TextBlock Text="Clear" />
                                            </Button>
                                        </StackPanel>

                                        <Border Grid.Row="8"
                                                Height="1"
                                                Background="{DynamicResource Brush.Border}" />

                                        <TextBlock Grid.Row="10"
                                                   Text="Edit Selected Item"
                                                   Style="{StaticResource TextBlock.SectionTitle}" />

                                        <Grid Grid.Row="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="12" />
                                                <ColumnDefinition Width="90" />
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="Value"
                                                           Margin="0,0,0,6"
                                                           Style="{StaticResource TextBlock.Body}" />
                                                <TextBox x:Name="ReligiousAffiliationValueTextBox"
                                                         MinHeight="36" />
                                            </StackPanel>

                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="Sort"
                                                           Margin="0,0,0,6"
                                                           Style="{StaticResource TextBlock.Body}" />
                                                <TextBox x:Name="ReligiousAffiliationSortTextBox"
                                                         MinHeight="36" />
                                            </StackPanel>
                                        </Grid>

                                        <StackPanel Grid.Row="14"
                                                    Orientation="Horizontal"
                                                    Margin="0,12,0,0">
                                            <Button x:Name="SaveReligiousAffiliationEditButton"
                                                    MinWidth="120"
                                                    Padding="14,8"
                                                    Click="SaveReligiousAffiliationEditButton_Click">
                                                <TextBlock Text="Save Update" />
                                            </Button>

                                            <Button x:Name="CancelReligiousAffiliationEditButton"
                                                    MinWidth="100"
                                                    Padding="14,8"
                                                    Margin="8,0,0,0"
                                                    Click="CancelReligiousAffiliationEditButton_Click">
                                                <TextBlock Text="Cancel" />
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </ScrollViewer>
                            </Border>

                            <Border Grid.Column="2"
                                    Style="{StaticResource CardBorderStyle}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="16" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Text="Religious Affiliation List"
                                               Style="{StaticResource TextBlock.SectionTitle}" />

                                    <DataGrid Grid.Row="2"
                                              x:Name="ReligiousAffiliationsDataGrid"
                                              AutoGenerateColumns="False"
                                              CanUserAddRows="False"
                                              HeadersVisibility="Column"
                                              IsReadOnly="True"
                                              RowHeaderWidth="0"
                                              MinHeight="440">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Value"
                                                                Binding="{Binding Value}"
                                                                Width="*" />

                                            <DataGridTextColumn Header="Sort"
                                                                Binding="{Binding SortOrder}"
                                                                Width="90" />

                                            <DataGridTemplateColumn Header="Action"
                                                                    Width="110">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Orientation="Horizontal"
                                                                    HorizontalAlignment="Center">
                                                            <Button Width="32"
                                                                    Height="32"
                                                                    Margin="0,0,8,0"
                                                                    Padding="0"
                                                                    ToolTip="Edit"
                                                                    Tag="{Binding}"
                                                                    Click="EditReligiousAffiliationButton_Click"
                                                                    Style="{StaticResource IconButtonStyle}">
                                                                <controls:ControlSvgIcon Width="16"
                                                                                         Height="16"
                                                                                         Source="/Modules/Learners/Resources/Icons/edit.svg"
                                                                                         Tint="{DynamicResource Brush.PrimaryText}" />
                                                            </Button>

                                                            <Button Width="32"
                                                                    Height="32"
                                                                    Padding="0"
                                                                    ToolTip="Delete"
                                                                    Tag="{Binding}"
                                                                    Click="DeleteReligiousAffiliationButton_Click"
                                                                    Style="{StaticResource IconButtonStyle}">
                                                                <controls:ControlSvgIcon Width="16"
                                                                                         Height="16"
                                                                                         Source="/Modules/Learners/Resources/Icons/delete.svg"
                                                                                         Tint="{DynamicResource Brush.PrimaryText}" />
                                                            </Button>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </Border>
                        </Grid>
                    </TabItem>
                </TabControl>
            </Grid>
        </Grid>
    </Border>
</Window>