<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <SolidColorBrush x:Key="Brush.Background" Color="#FF0B0B0C"/>
    <SolidColorBrush x:Key="Brush.Surface" Color="#FF16181B"/>
    <SolidColorBrush x:Key="Brush.SurfaceAlt" Color="#FF1D2126"/>
    <SolidColorBrush x:Key="Brush.Border" Color="#FF2A2F36"/>

    <SolidColorBrush x:Key="Brush.PrimaryText" Color="#FFF7F7FF"/>
    <SolidColorBrush x:Key="Brush.SecondaryText" Color="#FFC9D0D8"/>
    <SolidColorBrush x:Key="Brush.MutedText" Color="#FF9CA3AF"/>

    <SolidColorBrush x:Key="Brush.PrimaryAccent" Color="#FF279AF1"/>
    <SolidColorBrush x:Key="Brush.PrimaryAccentHover" Color="#FF23B5D3"/>
    <SolidColorBrush x:Key="Brush.SecondaryAccent" Color="#FF23B5D3"/>

    <SolidColorBrush x:Key="Brush.NavBackground" Color="#FF070600"/>
    <SolidColorBrush x:Key="Brush.NavItemHover" Color="#FF16181B"/>
    <SolidColorBrush x:Key="Brush.NavItemActive" Color="#FF279AF1"/>
    <SolidColorBrush x:Key="Brush.NavIcon" Color="#FFF7F7FF"/>

    <SolidColorBrush x:Key="Brush.InputReadOnlyBackground" Color="#FF202329"/>

    <SolidColorBrush x:Key="Brush.TabBackground" Color="#FF1D2126"/>
    <SolidColorBrush x:Key="Brush.TabForeground" Color="#FFC9D0D8"/>
    <SolidColorBrush x:Key="Brush.TabActiveBackground" Color="#FF2A2F36"/>
    <SolidColorBrush x:Key="Brush.TabActiveForeground" Color="#FFFFFFFF"/>

    <SolidColorBrush x:Key="Brush.GridHeaderBackground" Color="#FF1D2126"/>
    <SolidColorBrush x:Key="Brush.GridRowBackground" Color="#FF16181B"/>
    <SolidColorBrush x:Key="Brush.GridAlternateRowBackground" Color="#FF111315"/>
    <SolidColorBrush x:Key="Brush.GridSelectionBackground" Color="#FF203A52"/>

    <SolidColorBrush x:Key="Brush.IconButtonBackground" Color="Transparent"/>
    <SolidColorBrush x:Key="Brush.IconButtonHoverBackground" Color="#33279AF1"/>

    <SolidColorBrush x:Key="Brush.PopupBackground" Color="#FF16181B"/>

</ResourceDictionary>