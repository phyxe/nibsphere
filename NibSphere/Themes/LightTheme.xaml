<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Raw palette tokens -->
    <Color x:Key="Color.Token.Base.Dark">#FF000000</Color>
    <Color x:Key="Color.Token.Base.Light">#FFFFFFFF</Color>

    <Color x:Key="Color.Token.Primary.0">#FF2C83B2</Color>
    <Color x:Key="Color.Token.Primary.10">#FF2A749C</Color>
    <Color x:Key="Color.Token.Primary.20">#FF286587</Color>
    <Color x:Key="Color.Token.Primary.30">#FF255673</Color>
    <Color x:Key="Color.Token.Primary.40">#FF22485F</Color>
    <Color x:Key="Color.Token.Primary.50">#FF1E3A4C</Color>
    <Color x:Key="Color.Token.Primary.60">#FF192D3A</Color>
    <Color x:Key="Color.Token.Primary.70">#FF142028</Color>

    <Color x:Key="Color.Token.Surface.0">#FFFFF7F7</Color>
    <Color x:Key="Color.Token.Surface.10">#FFF0E9E9</Color>

    <Color x:Key="Color.Token.SurfaceTonal.0">#FFECEBF0</Color>
    <Color x:Key="Color.Token.SurfaceTonal.10">#FFDFDFE3</Color>
    <Color x:Key="Color.Token.SurfaceTonal.20">#FFD3D2D6</Color>

    <Color x:Key="Color.Token.Success">#FF1B7F5C</Color>
    <Color x:Key="Color.Token.Warning">#FFB8871F</Color>
    <Color x:Key="Color.Token.Danger">#FFB13535</Color>
    <Color x:Key="Color.Token.Info">#FF1E56A3</Color>

    <Color x:Key="Color.Token.Primary.Selection">#332C83B2</Color>
    <Color x:Key="Color.Token.Primary.HoverSoft">#142C83B2</Color>

    <!-- Semantic brushes used by the app -->
    <SolidColorBrush x:Key="Brush.Background" Color="{StaticResource Color.Token.SurfaceTonal.0}" />
    <SolidColorBrush x:Key="Brush.Surface" Color="{StaticResource Color.Token.Surface.0}" />
    <SolidColorBrush x:Key="Brush.SurfaceAlt" Color="{StaticResource Color.Token.Surface.10}" />
    <SolidColorBrush x:Key="Brush.Border" Color="{StaticResource Color.Token.SurfaceTonal.20}" />

    <SolidColorBrush x:Key="Brush.PrimaryText" Color="{StaticResource Color.Token.Primary.70}" />
    <SolidColorBrush x:Key="Brush.SecondaryText" Color="{StaticResource Color.Token.Primary.50}" />
    <SolidColorBrush x:Key="Brush.MutedText" Color="{StaticResource Color.Token.Primary.30}" />

    <SolidColorBrush x:Key="Brush.PrimaryAccent" Color="{StaticResource Color.Token.Primary.0}" />
    <SolidColorBrush x:Key="Brush.PrimaryAccentHover" Color="{StaticResource Color.Token.Primary.10}" />
    <SolidColorBrush x:Key="Brush.SecondaryAccent" Color="{StaticResource Color.Token.Primary.20}" />

    <SolidColorBrush x:Key="Brush.NavBackground" Color="{StaticResource Color.Token.Primary.50}" />
    <SolidColorBrush x:Key="Brush.NavItemHover" Color="{StaticResource Color.Token.Primary.40}" />
    <SolidColorBrush x:Key="Brush.NavItemActive" Color="{StaticResource Color.Token.Primary.0}" />
    <SolidColorBrush x:Key="Brush.NavIcon" Color="{StaticResource Color.Token.Base.Light}" />

    <SolidColorBrush x:Key="Brush.InputReadOnlyBackground" Color="{StaticResource Color.Token.Surface.10}" />

    <SolidColorBrush x:Key="Brush.TabBackground" Color="{StaticResource Color.Token.SurfaceTonal.0}" />
    <SolidColorBrush x:Key="Brush.TabForeground" Color="{StaticResource Color.Token.Primary.50}" />
    <SolidColorBrush x:Key="Brush.TabActiveBackground" Color="{StaticResource Color.Token.Surface.0}" />
    <SolidColorBrush x:Key="Brush.TabActiveForeground" Color="{StaticResource Color.Token.Primary.70}" />

    <SolidColorBrush x:Key="Brush.GridHeaderBackground" Color="{StaticResource Color.Token.SurfaceTonal.0}" />
    <SolidColorBrush x:Key="Brush.GridRowBackground" Color="{StaticResource Color.Token.Surface.0}" />
    <SolidColorBrush x:Key="Brush.GridAlternateRowBackground" Color="{StaticResource Color.Token.Surface.10}" />
    <SolidColorBrush x:Key="Brush.GridSelectionBackground" Color="{StaticResource Color.Token.Primary.Selection}" />

    <SolidColorBrush x:Key="Brush.IconButtonBackground" Color="Transparent" />
    <SolidColorBrush x:Key="Brush.IconButtonHoverBackground" Color="{StaticResource Color.Token.Primary.HoverSoft}" />

    <SolidColorBrush x:Key="Brush.PopupBackground" Color="{StaticResource Color.Token.Surface.0}" />

    <!-- Safe extra semantic brushes for future use -->
    <SolidColorBrush x:Key="Brush.Success" Color="{StaticResource Color.Token.Success}" />
    <SolidColorBrush x:Key="Brush.Warning" Color="{StaticResource Color.Token.Warning}" />
    <SolidColorBrush x:Key="Brush.Danger" Color="{StaticResource Color.Token.Danger}" />
    <SolidColorBrush x:Key="Brush.Info" Color="{StaticResource Color.Token.Info}" />

    <SolidColorBrush x:Key="Brush.TitleBarBackground" Color="{StaticResource Color.Token.Surface.0}" />
    <SolidColorBrush x:Key="Brush.TitleBarForeground" Color="{StaticResource Color.Token.Primary.70}" />
    <SolidColorBrush x:Key="Brush.TitleBarButtonHoverBackground" Color="{StaticResource Color.Token.SurfaceTonal.10}" />
    <SolidColorBrush x:Key="Brush.TitleBarCloseButtonHoverBackground" Color="{StaticResource Color.Token.Danger}" />

</ResourceDictionary>